{
  "name": "miniapp",
  "version": "1.0.0",
  "description": "Fastfood Kitchen miniapp",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev:weapp",
    "build": "npm run build:weapp",
    "lint": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "dev:weapp": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && node ../../node_modules/@tarojs/cli/bin/taro build --type weapp --watch",
    "build:weapp": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && node ../../node_modules/@tarojs/cli/bin/taro build --type weapp"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@fastfood-kitchen/api-client": "1.0.0",
    "@fastfood-kitchen/config": "1.0.0",
    "@nutui/nutui-react-taro": "^3.0.19-cpp.29-beta.1",
    "@tarojs/components": "^3.6.20",
    "@tarojs/helper": "^3.6.20",
    "@tarojs/plugin-framework-react": "^3.6.20",
    "@tarojs/react": "^3.6.20",
    "@tarojs/runtime": "^3.6.20",
    "@tarojs/shared": "^3.6.20",
    "@tarojs/taro": "^3.6.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.4.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@tarojs/cli": "^3.6.20",
    "@tarojs/plugin-platform-weapp": "^3.6.20",
    "@tarojs/taro-loader": "^3.6.20",
    "@tarojs/webpack5-runner": "^3.6.20",
    "@types/node": "^18.19.123",
    "@types/react": "^18.2.0",
    "@types/webpack-env": "^1.18.8",
    "babel-preset-taro": "^3.6.20",
    "postcss": "^8.5.6",
    "sass": "^1.99.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.8.2",
    "webpack": "^5.78.0"
  },
  "optionalDependencies": {
    "@swc/core-win32-x64-msvc": "^1.3.96"
  }
}
