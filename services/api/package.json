{
  "name": "api",
  "version": "1.0.0",
  "description": "Fastfood Kitchen Backend API",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "format": "node ../../node_modules/prettier/bin/prettier.cjs --write \"src/**/*.ts\"",
    "start": "node dist/main",
    "dev": "node ../../node_modules/ts-node/dist/bin.js src/main.ts",
    "debug": "node --inspect ../../node_modules/ts-node/dist/bin.js src/main.ts",
    "lint": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json --noEmit",
    "test": "npm run build && node --test \"dist/modules/costing/*.test.js\"",
    "migration:run": "npm run build && node ../../node_modules/typeorm/cli.js -d dist/database/data-source.js migration:run",
    "migration:revert": "npm run build && node ../../node_modules/typeorm/cli.js -d dist/database/data-source.js migration:revert",
    "migration:show": "npm run build && node ../../node_modules/typeorm/cli.js -d dist/database/data-source.js migration:show"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.1",
    "@types/supertest": "^7.2.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "sql.js": "^1.14.1",
    "supertest": "^7.2.2",
    "typeorm": "^0.3.28",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.1.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
