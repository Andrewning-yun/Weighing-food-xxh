{
  "info": {
    "name": "Fastfood Kitchen API",
    "_postman_id": "3edba713-6a78-4b9e-9d06-9af72ec1f7fd",
    "description": "MVP API collection for login, ingredients, dishes, users, and stores.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "admin1234" },
    { "key": "token", "value": "" },
    { "key": "ingredientId", "value": "" },
    { "key": "dishId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = pm.response.json();",
                  "pm.collectionVariables.set('token', payload.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Ingredients",
      "item": [
        {
          "name": "List Ingredients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/ingredients"
          }
        },
        {
          "name": "Create Ingredient",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = pm.response.json();",
                  "pm.collectionVariables.set('ingredientId', payload.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Ingredient\",\n  \"unit\": \"kg\",\n  \"price\": 12.5,\n  \"costPerUnit\": 12.5,\n  \"spec\": \"1kg / pack\"\n}"
            },
            "url": "{{baseUrl}}/ingredients"
          }
        },
        {
          "name": "Update Ingredient",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 14\n}" },
            "url": "{{baseUrl}}/ingredients/{{ingredientId}}"
          }
        },
        {
          "name": "Delete Ingredient",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/ingredients/{{ingredientId}}"
          }
        }
      ]
    },
    {
      "name": "Dishes",
      "item": [
        {
          "name": "List Dishes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dishes"
          }
        },
        {
          "name": "Create Dish",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = pm.response.json();",
                  "pm.collectionVariables.set('dishId', payload.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Dish\",\n  \"category\": \"rice\",\n  \"station\": \"station_1\",\n  \"ingredients\": [],\n  \"steps\": [],\n  \"expectedGrossMargin\": 0.6\n}"
            },
            "url": "{{baseUrl}}/dishes"
          }
        },
        {
          "name": "Update Dish",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated from Postman\"\n}" },
            "url": "{{baseUrl}}/dishes/{{dishId}}"
          }
        },
        {
          "name": "Delete Dish",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dishes/{{dishId}}"
          }
        }
      ]
    },
    {
      "name": "Users And Stores",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "List Stores",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/stores"
          }
        }
      ]
    }
  ]
}
